{
  "name": "stratum-client-ts",
  "version": "0.1.0",
  "description": "Browser-compatible Stratum v1 client for Lotus native SHA-256 mining",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./node": {
      "types": "./dist/types/node.d.ts",
      "import": "./dist/esm/node.js",
      "require": "./dist/cjs/node.js"
    },
    "./lib/*": {
      "types": "./dist/types/lib/*.d.ts",
      "import": "./dist/esm/lib/*.js",
      "require": "./dist/cjs/lib/*.js"
    }
  },
  "scripts": {
    "build": "gulp build",
    "build:clean": "gulp clean",
    "build:types": "gulp build:types",
    "build:esm": "gulp build:esm",
    "build:cjs": "gulp build:cjs",
    "build:validate": "gulp validate",
    "build:watch": "gulp watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "version": "npm run build",
    "postversion": "git push && git push --tags"
  },
  "keywords": [
    "lotus",
    "stratum",
    "mining",
    "browser",
    "typescript"
  ],
  "author": "Lotusia Stewardship",
  "license": "MIT",
  "dependencies": {
    "@noble/hashes": "^1.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "24.0.10",
    "gulp": "5.0.1",
    "gulp-cli": "3.1.0",
    "jest": "^29.7.0",
    "prettier": "3.6.2",
    "ts-jest": "^29.1.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.47.0"
  }
}
