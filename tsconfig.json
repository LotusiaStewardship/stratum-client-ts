{
  "exclude": ["node_modules", "dist", "test", "examples", "**/*.test.ts"],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist/esm",
    "declaration": false,
    "declarationMap": false,
    "removeComments": true,
    "esModuleInterop": false,
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2023", "DOM"]
  }
}
